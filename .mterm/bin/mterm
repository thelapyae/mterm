#!/bin/bash
if [ "$1" == "--version" ]; then
  echo "mterm version 1.0.1"
elif [ "$1" == "--update" ]; then
  echo "Checking for updates..."
  # We will use an IPC signal here via a custom protocol or just a simple file flag
  echo "Update feature is being integrated. Please check GitHub for now."
else
  echo "mterm: Unknown command. Use --version or --update."
fi
